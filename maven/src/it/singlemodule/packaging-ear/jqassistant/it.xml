<jqa:jqassistant-rules xmlns:jqa="http://www.buschmais.com/jqassistant/core/analysis/rules/schema/v1.0">

    <group id="it">
        <includeConcept refId="it:*" />
    </group>

    <concept id="it:ProjectContainsApplicationXML" severity="blocker">
        <description>The project contains the file "/META-INF/application.xml" .</description>
        <cypher>
            MATCH
              (:Maven:Project)-[:CONTAINS]->(application:Directory{fileName:"src/main/application"}),
              (webapp)-[:CONTAINS]->(applicationXml:Xml:File{fileName:"/META-INF/application.xml"})
            RETURN
              applicationXml
        </cypher>
    </concept>

</jqa:jqassistant-rules>
