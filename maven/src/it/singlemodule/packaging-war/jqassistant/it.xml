<jqa:jqassistant-rules xmlns:jqa="http://www.buschmais.com/jqassistant/core/analysis/rules/schema/v1.0">

    <group id="it">
        <includeConcept refId="it:*" />
    </group>

    <concept id="it:ProjectContainsWebXML" severity="blocker">
        <description>The project contains the file "/WEB-INF/web.xml" .</description>
        <cypher>
            MATCH
              (:Maven:Project)-[:CONTAINS]->(webapp:Directory{fileName:"src/main/webapp"}),
              (webapp)-[:CONTAINS]->(webXml:Xml:File{fileName:"/WEB-INF/web.xml"})
            RETURN
              webXml
        </cypher>
    </concept>

</jqa:jqassistant-rules>
