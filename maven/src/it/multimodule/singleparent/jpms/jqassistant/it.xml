<jqassistant-rules xmlns="http://schema.jqassistant.org/rule/v1.10"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://schema.jqassistant.org/rule/v1.10 http://schema.jqassistant.org/rule/jqassistant-rule-v1.10.xsd">

    <group id="it">
        <includeConcept refId="it:*" severity="blocker" />
    </group>

    <concept id="it:Module1AnnotatedByDeprecated">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (module1)-[:ANNOTATED_BY]->()-[:OF_TYPE]->(:Type{fqn:"java.lang.Deprecated"})
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1DependsOnDeprecated">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (module1)-[:DEPENDS_ON{weight:1}]->(:Type{fqn:"java.lang.Deprecated"})
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1RequiresJacksonCore">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (jacksonCore:Artifact{name:"jackson-core"}),
              (jacksonCore)-[:PROVIDES]->(module2:Java:Module{fqn:"com.fasterxml.jackson.core"}),
              (module1)-[:REQUIRES]->(module2)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1ExportsApiPackage">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(api:Java:Package{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.api"}),
              (module1)-[:EXPORTS]->(exportedPackage:Java:ExportedPackage),
              (exportedPackage)-[:OF_PACKAGE]->(api)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1ExportsImplPackageToModule2">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(impl:Java:Package{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.impl"}),
              (module1)-[:EXPORTS]->(exportedPackage:Java:ExportedPackage),
              (exportedPackage)-[:OF_PACKAGE]->(impl),
              (exportedPackage)-[:TO_MODULE]->(module2:Java:Module{fqn:"jpms.module2"}),
              (artifact1)-[:REQUIRES]->(module2)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1OpensApiPackage">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(api:Java:Package{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.api"}),
              (module1)-[:OPENS]->(openPackage:Java:OpenPackage),
              (openPackage)-[:OF_PACKAGE]->(api)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1OpensImplPackageToModule2">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(impl:Java:Package{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.impl"}),
              (module1)-[:OPENS]->(openPackage:Java:OpenPackage),
              (openPackage)-[:OF_PACKAGE]->(impl),
              (openPackage)-[:TO_MODULE]->(module2:Java:Module{fqn:"jpms.module2"}),
              (artifact1)-[:REQUIRES]->(module2)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1ProvidesService">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(serviceType:Java:Type{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.api.MyService"}),
              (artifact1)-[:PROVIDES]->(providerType:Java:Type{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.impl.MyServiceImpl"}),
              (module1)-[:PROVIDES]->(providedService:Java:ProvidedService),
              (providedService)-[:OF_TYPE]->(serviceType),
              (providedService)-[:WITH_PROVIDER]->(providerType)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module1ProvidesInnerService">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(serviceType:Java:Type{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.api.MyService$InnerService"}),
              (artifact1)-[:PROVIDES]->(providerType:Java:Type{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.impl.MyServiceImpl$InnerServiceImpl"}),
              (module1)-[:PROVIDES]->(providedService:Java:ProvidedService),
              (providedService)-[:OF_TYPE]->(serviceType),
              (providedService)-[:WITH_PROVIDER]->(providerType)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module2UsesService">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (module1)-[:PROVIDES]->(providedService:Java:ProvidedService)-[:OF_TYPE]->(serviceType:Java:Type{fqn:"com.buschmais.jqassistant.maven.it.jpms.module1.api.MyService"}),
              (artifact2:Artifact{name:"jpms.module2"}),
              (artifact2)-[:PROVIDES]->(module2:Java:Module{fqn:"jpms.module2"}),
              (module2)-[:USES]->(serviceType)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module2RequiresModule1">
        <cypher><![CDATA[
            MATCH
              (artifact1:Artifact{name:"jpms.module1"}),
              (artifact1)-[:PROVIDES]->(module1:Java:Module{fqn:"jpms.module1"}),
              (artifact2:Artifact{name:"jpms.module2"}),
              (artifact2)-[:PROVIDES]->(module2:Java:Module{fqn:"jpms.module2"}),
              (module2)-[:REQUIRES]->(module1)
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:OpenModule2">
        <cypher><![CDATA[
            MATCH
              (artifact2:Artifact{name:"jpms.module2"}),
              (artifact2)-[:PROVIDES]->(module2:Java:Module{fqn:"jpms.module2", open:true})
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

    <concept id="it:Module2RequiresStaticTransitiveModuleJavaSE">
        <cypher><![CDATA[
            MATCH
              (artifact2:Artifact{name:"jpms.module2"}),
              (artifact2)-[:PROVIDES]->(module2:Java:Module{fqn:"jpms.module2"}),
              (module2)-[:REQUIRES{static:true, transitive:true}]->(:Java:Module{fqn:"java.se"})
            RETURN
              *
        ]]></cypher>
        <verify>
            <rowCount min="1" max="1"/>
        </verify>
    </concept>

</jqassistant-rules>
